{
  "manifest_version": 3,
  "name": "Hide Streamed YouTube Videos",
  "version": "1.0.0",
  "description": "Automatically hides YouTube video cards marked as streamed a number of days ago.",
  "content_scripts": [
    {
      "matches": [
        "*://youtube.com/*",
        "*://*.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
