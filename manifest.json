{
  "manifest_version": 3,
  "name": "YouTube Hide",
  "version": "1.5.0",
  "description": "Hide streamed videos, Shorts, Mixes, music videos, and other clutter on YouTube.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "action": {
    "default_title": "YouTube Hide",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://youtube.com/*",
        "*://*.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
